{
  "schemaVersion": 2,
  "status": "repository-readiness-only",
  "defaultDeploymentReachability": "public-unless-cloudflare-access-is-enabled",
  "accessConfirmationVariable": "TALLYO_CLOUDFLARE_ACCESS_CONFIRMED",
  "projects": {
    "website": {
      "expectedName": "tallyo-website",
      "rootDirectory": "website",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "previewMode": "noindex",
      "accessPolicyRequiredBeforeFirstSuccessfulDeploy": true,
      "productionBuildRequiresOwnerApproval": true
    },
    "app": {
      "expectedName": "tallyo-app",
      "rootDirectory": ".",
      "buildCommand": "node scripts/build-app-pages.mjs",
      "outputDirectory": "app-dist",
      "previewMode": "noindex",
      "accessPolicyRequiredBeforeFirstSuccessfulDeploy": true,
      "productionBuildRequiresOwnerApproval": true
    }
  },
  "liveDnsChanged": false,
  "providerProjectsCreated": false,
  "existingGitHubPagesRollbackRetained": true
}
